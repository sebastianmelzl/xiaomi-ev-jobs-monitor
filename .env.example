# Application
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=false

# Database
DATABASE_URL=sqlite:///./data/jobs.db
# For Postgres: DATABASE_URL=postgresql://user:pass@localhost:5432/xiaomi_ev_jobs

# Scraper
SCRAPER_HEADLESS=true
SCRAPER_MIN_DELAY_S=2.0
SCRAPER_MAX_DELAY_S=5.0
SCRAPER_MAX_RETRIES=3
SCRAPER_TIMEOUT_MS=30000

# LinkedIn (optional — authenticated scraping for applicant counts)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Archiving
ARCHIVE_MISSING_THRESHOLD=3

# Scheduler
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_HOURS=12
